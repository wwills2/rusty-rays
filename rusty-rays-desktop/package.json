{
  "name": "rusty-rays-desktop",
  "homepage": "https://github.com/wwills2/rusty-rays",
  "description": "Rust based Rayshade4 ray tracer",
  "author": "William Wills <wwills2@protonmail.com>",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run vite\" \"npm run electron:dev\"",
    "vite": "npx vite -c vite.renderer.config.ts",
    "build": "npm run build:main && npx vite -c vite.renderer.config.ts build",
    "build:main": "tsc -p tsconfig.electron.main.json && node esbuild.run.js",
    "dist": "npm run clean && npm run build && npx electron-builder --linux deb",
    "electron:dev": "npm run build:main && npx cross-env SPA_SRC=vite npx electron .",
    "electron": "npm run build && npx electron .",
    "lint": "npx eslint . --fix && npx prettier . --write",
    "clean": "npx rimraf ./dist && npx rimraf ./build"
  },
  "build": {
    "appId": "com.wwills2.rusty-rays",
    "productName": "Rusty Rays",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "!build/**/*.map"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "rusty-rays-napi-node": "file:../rusty-rays-napi-node"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "daisyui": "^5.5.5",
    "dotenv": "^17.2.3",
    "electron": "^39.2.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.0",
    "esbuild-plugin-copy": "^2.1.1",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-react-dom": "^2.3.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-react-x": "^2.3.5",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.0",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2"
  }
}
